body { font-family: Arial, sans-serif; padding: 20px; }
h2 { margin-bottom: 10px; }
.categoria, .subcategoria { cursor: pointer; color: blue; text-decoration: underline; margin: 5px 0; }
.categoria:hover, .subcategoria:hover { color: darkblue; }
table { width: 80%; border-collapse: collapse; margin: 10px 0 20px 0; }
th, td { padding: 8px; border: 1px solid #ccc; text-align: center; }
th { background: #eaeaea; }
button, select { margin: 5px; padding: 5px 10px; }
.paginacion { margin: 10px 0; }
